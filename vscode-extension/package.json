{
  "name": "interact-mcp",
  "displayName": "Interact MCP",
  "description": "Configure and run the Interact MCP server for browser automation",
  "version": "0.1.0",
  "preview": true,
  "publisher": "AlanBlanchet",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AlanBlanchet/interact-mcp"
  },
  "homepage": "https://github.com/AlanBlanchet/interact-mcp#readme",
  "bugs": {
    "url": "https://github.com/AlanBlanchet/interact-mcp/issues"
  },
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "interact-mcp"
      }
    ],
    "configuration": {
      "title": "Interact MCP",
      "properties": {
        "interactMcp.projectPath": {
          "type": "string",
          "default": "",
          "description": "Local project path for development (uses 'uv run' instead of 'uvx'). Leave empty when installed from PyPI."
        },
        "interactMcp.imageModel": {
          "type": "string",
          "default": "",
          "description": "Vision model for screenshot/image analysis (e.g. gpt-4.1, claude-sonnet-4-6)"
        },
        "interactMcp.videoModel": {
          "type": "string",
          "default": "",
          "description": "Vision model for video analysis (e.g. gemini/gemini-2.5-flash)"
        },
        "interactMcp.imageBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Custom base URL for image model API"
        },
        "interactMcp.videoBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Custom base URL for video model API"
        },
        "interactMcp.headless": {
          "type": "boolean",
          "default": true,
          "description": "Run browser in headless mode"
        },
        "interactMcp.slowMo": {
          "type": "number",
          "default": 0,
          "description": "Slow down browser actions by this many milliseconds (useful for observing automation)"
        },
        "interactMcp.browserType": {
          "type": "string",
          "default": "chromium",
          "enum": [
            "chromium",
            "firefox",
            "webkit"
          ],
          "description": "Browser engine"
        },
        "interactMcp.viewportWidth": {
          "type": "number",
          "default": 1280,
          "description": "Browser viewport width"
        },
        "interactMcp.viewportHeight": {
          "type": "number",
          "default": 720,
          "description": "Browser viewport height"
        },
        "interactMcp.videoFps": {
          "type": "number",
          "default": 5,
          "description": "Frames per second for video capture"
        },
        "interactMcp.videoDuration": {
          "type": "number",
          "default": 3,
          "description": "Duration in seconds for video capture"
        },
        "interactMcp.maxTokens": {
          "type": "number",
          "default": 2048,
          "description": "Maximum tokens for VLM vision responses"
        },
        "interactMcp.waitTimeout": {
          "type": "number",
          "default": 10000,
          "description": "Default timeout in ms for waiting on elements"
        },
        "interactMcp.screenshotDumpDir": {
          "type": "string",
          "default": "",
          "description": "Save every screenshot to this folder as timestamped PNGs (for debugging)"
        }
      }
    },
    "commands": [
      {
        "command": "interactMcp.selectModel",
        "title": "Interact MCP: Select Model"
      },
      {
        "command": "interactMcp.manageApiKeys",
        "title": "Interact MCP: Manage API Keys"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && node -e \"try{require('fs').cpSync('src/models.json','out/models.json')}catch{}\"",
    "watch": "tsc -watch -p ./",
    "generate-models": "python scripts/generate-models.py"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.99.0",
    "@vscode/vsce": "^3.5.0",
    "typescript": "^5.7.0"
  }
}
